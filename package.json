{
  "name": "malik-web-game",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev:all": "npm run dev --workspace=server & npm run dev --workspace=client",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "build:client": "npm run build --workspace=client",
    "test": "npm run test --workspace=@malik/shared",
    "preview": "npm run preview --workspace=client",
    "db:push": "npm run db:push --workspace=server"
  }
}
